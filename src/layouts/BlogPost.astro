---
import BaseLayout from "../layouts/BaseLayout.astro"
export interface Props {
  content: {
    title: string
    description: string
    pubDate?: string
    updatedDate?: string
    heroImage?: string
  }
}

const {
  content: { title, pubDate, updatedDate, heroImage },
} = Astro.props
---

<BaseLayout lang="de" showMainContent={false}>
  <main class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <article>
      {heroImage && <img width={720} height={360} src={heroImage} alt="" />}
      <h1
        class="text-4xl tracking-tight font-extrabold text-black sm:text-5xl md:text-5xl"
      >
        {title}
      </h1>
      {pubDate && <time>{pubDate}</time>}
      {
        updatedDate && (
          <div>
            Zuletzt geändert am <time>{updatedDate}</time>
          </div>
        )
      }
      <hr class="my-4" />
      <slot />
    </article>
  </main>
</BaseLayout>
